{
  "name": "uamme",
  "version": "1.0.0",
  "description": "优安米 - 企业微信 Webhook 推送机器人配置平台",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute uamme-db --file=./migrations/0001_init.sql",
    "db:init:local": "wrangler d1 execute uamme-db --local --file=./migrations/0001_init.sql",
    "db:seed": "wrangler d1 execute uamme-db --file=./migrations/0002_seed.sql",
    "db:seed:local": "wrangler d1 execute uamme-db --local --file=./migrations/0002_seed.sql"
  },
  "dependencies": {
    "hono": "^4.0.0"
  }
}
